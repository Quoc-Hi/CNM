<!DOCTYPE html>
<html>
<head>
<title>Products</title>
</head>
<body>

<h1>Product List</h1>

<a href="/add">Add Product</a>

<table border="1">
<tr>
<th>ID</th>
<th>Name</th>
<th>Price</th>
<th>Image</th>
<th>Action</th>
</tr>

<% products.forEach(product => { %>
<tr>
<td><%= product.id %></td>
<td><%= product.name %></td>
<td><%= product.price %></td>
<td>
<img src="<%= product.url_image %>" width="80">
</td>
<td>
<a href="/delete/<%= product.id %>">Delete</a>
</td>
</tr>
<% }) %>

</table>

</body>
</html>