<%- include('partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-list-check me-2 text-primary"></i>Danh sách sản phẩm</h2>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>
            <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <% } %>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <form action="/" method="GET" class="d-flex">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i
                                    class="fa-solid fa-search text-muted"></i></span>
                            <input type="text" name="search" class="form-control border-start-0 ps-0"
                                placeholder="Tìm kiếm theo tên sản phẩm..." value="<%= searchQuery %>">
                            <button type="submit" class="btn btn-primary px-4">Tìm kiếm</button>
                            <% if (searchQuery) { %>
                                <a href="/" class="btn btn-outline-secondary px-3">Xóa lọc</a>
                                <% } %>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th class="text-end pe-4">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (products.length> 0) { %>
                                    <% products.forEach(product=> { %>
                                        <tr>
                                            <td class="ps-4 fw-medium text-muted">
                                                <%= product.ID %>
                                            </td>
                                            <td>
                                                <% if (product.image) { %>
                                                    <img src="<%= product.image %>" alt="<%= product.name %>"
                                                        class="rounded object-fit-cover shadow-sm" width="60"
                                                        height="60">
                                                    <% } else { %>
                                                        <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted shadow-sm"
                                                            style="width: 60px; height: 60px;">
                                                            <i class="fa-solid fa-image"></i>
                                                        </div>
                                                        <% } %>
                                            </td>
                                            <td class="fw-semibold">
                                                <%= product.name %>
                                            </td>
                                            <td class="text-success fw-bold">
                                                <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                                    }).format(product.price) %>
                                            </td>
                                            <td>
                                                <span
                                                    class="badge <%= product.quantity > 0 ? 'bg-info' : 'bg-danger' %> rounded-pill px-3 py-2">
                                                    <%= product.quantity %>
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <a href="/edit/<%= product.ID %>"
                                                        class="btn btn-sm btn-outline-primary" title="Sửa">
                                                        <i class="fa-solid fa-pen-to-square"></i>
                                                    </a>
                                                    <form action="/delete/<%= product.ID %>" method="POST"
                                                        class="d-inline m-0" onsubmit="return confirmDelete()">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            title="Xóa">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="6" class="text-center py-5 text-muted">
                                                        <i class="fa-solid fa-box-open fa-3x mb-3 text-light"></i>
                                                        <h5>Không tìm thấy sản phẩm nào!</h5>
                                                        <p>Hãy thử tìm kiếm với từ khóa khác hoặc thêm sản phẩm mới.</p>
                                                    </td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <%- include('partials/footer') %>