# AWS Configuration
AWS_REGION=us-east-1
# Note: Use IAM Role when deployed to EC2 (no need for access key/secret)
# For local development, you can set these:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000

# S3
S3_BUCKET_NAME=product-management-images
S3_REGION=us-east-1

# Express
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=your_very_secret_key_here_change_in_production

# App
APP_NAME=Product Management System
