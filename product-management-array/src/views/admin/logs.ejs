<%- include('../partials/header') %>

<div class="container mt-5">
  <h2>Audit Logs</h2>

  <% if (logs && logs.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>Log ID</th>
            <th>Action</th>
            <th>Product ID</th>
            <th>User ID</th>
            <th>Time</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(log => { %>
            <tr>
              <td><code><%= log.logId %></code></td>
              <td><span class="badge bg-info"><%= log.action %></span></td>
              <td><code><%= log.productId %></code></td>
              <td><code><%= log.userId %></code></td>
              <td><%= new Date(log.time).toLocaleString() %></td>
              <td><%= log.details || '-' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
      <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
          <% if (pagination.hasPrev) { %>
            <li class="page-item">
              <a class="page-link" href="?page=<%= pagination.current - 1 %>">Previous</a>
            </li>
          <% } %>

          <% pagination.pages.forEach(page => { %>
            <li class="page-item <%= page === pagination.current ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= page %>"><%= page %></a>
            </li>
          <% }); %>

          <% if (pagination.hasNext) { %>
            <li class="page-item">
              <a class="page-link" href="?page=<%= pagination.current + 1 %>">Next</a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  <% } else { %>
    <div class="alert alert-info">No logs found.</div>
  <% } %>
</div>

<%- include('../partials/footer') %>
