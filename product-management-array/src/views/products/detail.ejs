<%- include('../partials/header') %>

<div class="container mt-5">
  <div class="row">
    <div class="col-md-8">
      <% if (product.url_image) { %>
        <img src="<%= product.url_image %>" class="img-fluid mb-4" alt="<%= product.name %>" style="max-height: 400px; object-fit: cover;">
      <% } else { %>
        <div class="bg-light d-flex align-items-center justify-content-center mb-4" style="height: 400px;">
          <span class="text-muted">No Image</span>
        </div>
      <% } %>

      <h2><%= product.name %></h2>
      <h3 class="text-primary mb-3">$<%= product.price.toFixed(2) %></h3>

      <div class="mb-3">
        <strong>Category:</strong> <a href="/categories/<%= product.categoryId %>"><%= category.name %></a>
      </div>

      <div class="mb-3">
        <strong>Quantity:</strong> <%= product.quantity %>
        <span class="badge bg-<%= require('../../../services/product.service').getInventoryStatusClass(product.quantity) %>">
          <%= productService.getInventoryStatus(product.quantity) %>
        </span>
      </div>

      <div class="mb-3">
        <strong>Created:</strong> <%= new Date(product.createdAt).toLocaleDateString() %>
      </div>

      <% if (user && user.role === 'admin') { %>
        <div class="mb-3">
          <a href="/products/<%= product.id %>/edit-form" class="btn btn-warning">Edit</a>
          <a href="/products/<%= product.id %>/delete" class="btn btn-danger" onclick="return confirm('Are you sure?');">Delete</a>
        </div>
      <% } %>

      <hr>

      <!-- Audit Logs -->
      <h5>Activity Log</h5>
      <% if (logs && logs.length > 0) { %>
        <table class="table table-sm table-striped">
          <thead>
            <tr>
              <th>Action</th>
              <th>User ID</th>
              <th>Time</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td><span class="badge bg-info"><%= log.action %></span></td>
                <td><code><%= log.userId %></code></td>
                <td><%= new Date(log.time).toLocaleString() %></td>
                <td><%= log.details || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="text-muted">No activity log yet.</p>
      <% } %>
    </div>

    <div class="col-md-4">
      <div class="card">
        <div class="card-header bg-light">
          <h5 class="mb-0">Quick Info</h5>
        </div>
        <div class="card-body">
          <dl class="row">
            <dt class="col-sm-8">Status:</dt>
            <dd class="col-sm-4">
              <span class="badge bg-<%= require('../../../services/product.service').getInventoryStatusClass(product.quantity) %>">
                <%= require('../../../services/product.service').getInventoryStatus(product.quantity) %>
              </span>
            </dd>
            <dt class="col-sm-8">Stock:</dt>
            <dd class="col-sm-4"><%= product.quantity %> units</dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <a href="/products" class="btn btn-secondary">← Back to Products</a>
  </div>
</div>

<%- include('../partials/footer') %>
